{
  "manifest_version": 3,
  "name": "小红书下拉词批量采集器",
  "version": "1.13",
  "description": "基于开源版增强：批量采集、递归长尾、上升趋势雷达、全历史记录（含快照）、账号登录云同步、CSV/TXT 与历史导出。",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "downloads",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*.xiaohongshu.com/*",
    "*://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.xiaohongshu.com/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://*.xiaohongshu.com/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "小红书下拉词批量采集器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
